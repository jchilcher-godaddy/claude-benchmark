<section id="summary">
  <h2>Executive Summary</h2>
  <div class="section-guide">Top-performing model/profile combinations and regression flags. Look for: which combo wins, overall best profile, and token efficiency.</div>

  <div class="summary-highlights">
    <div class="summary-card">
      <span class="card-label"><span class="metric-def">Best Model/Profile<span class="def-popup">The model and profile combination with the highest average composite score across all tasks and runs.</span></span></span>
      <span class="card-value">{{ best_combo_model }} / {{ best_combo_profile }}
        {% if best_combo_score > 0 %}
          <span style="font-size: 0.85rem; font-weight: 400;">({{ "%.1f"|format(best_combo_score) }})</span>
          {% if best_combo_score >= 90 %}<span class="score-tier tier-excellent">Excellent</span>
          {% elif best_combo_score >= 70 %}<span class="score-tier tier-good">Good</span>
          {% elif best_combo_score >= 50 %}<span class="score-tier tier-fair">Fair</span>
          {% else %}<span class="score-tier tier-poor">Poor</span>{% endif %}
        {% endif %}
      </span>
    </div>
    <div class="summary-card">
      <span class="card-label"><span class="metric-def">Best Profile Overall<span class="def-popup">The profile with the highest average quality score across all models.</span></span></span>
      <span class="card-value">{{ best_profile_overall }}
        {% if best_profile_score > 0 %}
          <span style="font-size: 0.85rem; font-weight: 400;">({{ "%.1f"|format(best_profile_score) }})</span>
          {% if best_profile_score >= 90 %}<span class="score-tier tier-excellent">Excellent</span>
          {% elif best_profile_score >= 70 %}<span class="score-tier tier-good">Good</span>
          {% elif best_profile_score >= 50 %}<span class="score-tier tier-fair">Fair</span>
          {% else %}<span class="score-tier tier-poor">Poor</span>{% endif %}
        {% endif %}
      </span>
    </div>
    <div class="summary-card">
      <span class="card-label"><span class="metric-def">Token Efficiency Winner<span class="def-popup">The model/profile combination with the highest quality-per-token ratio — best results for lowest cost.</span></span></span>
      <span class="card-value">{{ tw_model }} / {{ tw_profile }}
        {% if tw_score > 0 %}
          <span style="font-size: 0.85rem; font-weight: 400;">({{ "%.1f"|format(tw_score) }})</span>
          {% if tw_score >= 90 %}<span class="score-tier tier-excellent">Excellent</span>
          {% elif tw_score >= 70 %}<span class="score-tier tier-good">Good</span>
          {% elif tw_score >= 50 %}<span class="score-tier tier-fair">Fair</span>
          {% else %}<span class="score-tier tier-poor">Poor</span>{% endif %}
        {% endif %}
      </span>
    </div>
    <div class="summary-card">
      <span class="card-label">Profiles Tested</span>
      <span class="card-value">{{ profiles | length }}</span>
    </div>
    <div class="summary-card">
      <span class="card-label">Tasks Run</span>
      <span class="card-value">{{ tasks | length }}</span>
    </div>
  </div>

  {% if insights %}
  <div>
    <h3>Key Takeaways</h3>
    {% for insight in insights %}
    <div class="insight-callout">{{ insight }}</div>
    {% endfor %}
  </div>
  {% endif %}

  {% if llm_summary_text %}
  <div>
    <h3>LLM Analysis</h3>
    <div class="llm-summary-callout">
      {% for paragraph in llm_summary_text.split('\n\n') %}
        {% if paragraph.strip() %}
        <p>{{ paragraph.strip() }}</p>
        {% endif %}
      {% endfor %}
      <div class="llm-summary-attribution">Generated by Claude at report time</div>
    </div>
  </div>
  {% endif %}

  {% if category_analysis and category_analysis|length > 1 %}
  <div>
    <h3>Variant Analysis by Task Category</h3>
    <p style="margin-bottom: 0.75rem; color: #64748b; font-size: 0.9rem;">Different task categories may favor different profiles. Categories where the winner differs from the overall best are flagged.</p>
    <table class="score-table">
      <thead>
        <tr>
          <th>Category</th>
          <th>Tasks</th>
          <th>Best Profile</th>
          <th>Score</th>
          <th>Margin</th>
          <th>Spread</th>
        </tr>
      </thead>
      <tbody>
        {% for cat in category_analysis %}
        <tr>
          <td>{{ cat.category }}{% if cat.is_exception %} <span class="badge-regression" style="background:#ea580c;">EXCEPTION</span>{% endif %}</td>
          <td>{{ cat.task_count }}</td>
          <td>{{ cat.winner }}</td>
          <td>{{ "%.1f"|format(cat.winner_score) }}
            {% if cat.winner_score >= 90 %}<span class="score-tier tier-excellent">Excellent</span>
            {% elif cat.winner_score >= 70 %}<span class="score-tier tier-good">Good</span>
            {% elif cat.winner_score >= 50 %}<span class="score-tier tier-fair">Fair</span>
            {% else %}<span class="score-tier tier-poor">Poor</span>{% endif %}
          </td>
          <td style="color: {% if cat.margin < 2 %}#ea580c{% else %}#16a34a{% endif %};">+{{ "%.1f"|format(cat.margin) }}</td>
          <td>{{ "%.1f"|format(cat.spread) }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endif %}

  {% if model_preferences and model_preferences|length > 1 %}
  <div>
    <h3>Model-Specific Preferences</h3>
    <p style="margin-bottom: 0.75rem; color: #64748b; font-size: 0.9rem;">Each model may prefer a different profile. Models whose preference differs from the overall best are flagged.</p>
    <div class="summary-highlights">
      {% for pref in model_preferences %}
      <div class="summary-card">
        <span class="card-label">{{ pref.model }}</span>
        <span class="card-value">{{ pref.preferred_profile }}
          <span style="font-size: 0.85rem; font-weight: 400;">({{ "%.1f"|format(pref.score) }})</span>
          {% if pref.score >= 90 %}<span class="score-tier tier-excellent">Excellent</span>
          {% elif pref.score >= 70 %}<span class="score-tier tier-good">Good</span>
          {% elif pref.score >= 50 %}<span class="score-tier tier-fair">Fair</span>
          {% else %}<span class="score-tier tier-poor">Poor</span>{% endif %}
          {% if pref.is_exception %}<span class="badge-regression" style="background:#ea580c;">EXCEPTION</span>{% endif %}
        </span>
        <span class="card-subtitle" style="font-size: 0.8rem; color: #64748b;">spread: {{ "%.1f"|format(pref.spread) }} · margin: {{ "%.1f"|format(pref.margin) }}</span>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {% if regressions_list %}
  <div class="regression-callout">
    <h3>Regressions Detected ({{ regressions_list | length }})</h3>
    <ul>
      {% for r in regressions_list %}
      <li>
        <strong>{{ r.profile }}</strong> on {{ r.task }} / {{ r.dimension }}:
        {{ "%.1f"|format(r.delta_pct * 100) }}% (p={{ "%.3f"|format(r.p_value) }})
        <span class="badge-regression">REGRESSION</span>
      </li>
      {% endfor %}
    </ul>
  </div>
  {% else %}
  <div class="success-callout">
    <h3>No Regressions Detected</h3>
    <p>All profiles performed within expected ranges compared to baseline.</p>
  </div>
  {% endif %}
</section>
